---
interface Props {
  path: string;
}

const { path } = Astro.props;

const segments = path === '/' ? [] : path.split('/').filter(Boolean);
---
<div class="breadcrumb">
  <a href="/" class="prompt-user">lsalik@dev</a><span class="prompt-sep">:</span><span class="prompt-root">~</span>{segments.map((seg, i) => {
    const href = '/' + segments.slice(0, i + 1).join('/');
    const isCurrent = i === segments.length - 1;
    return <>{isCurrent
      ? <><span class="prompt-sep">/</span><span class="prompt-path-current">{seg}</span></>
      : <><span class="prompt-sep">/</span><a href={href} class="prompt-path">{seg}</a></>}</>;
  })}<span class="prompt-dollar">$</span><span class="cursor" aria-hidden="true"></span>
</div>

<style>
  .breadcrumb {
    font-size: 1rem;
  }

  .prompt-user {
    color: var(--green);
    text-decoration: none;
  }

  .prompt-user:hover {
    color: var(--accent-bright);
  }

  .prompt-sep {
    color: var(--fg-muted);
  }

  .prompt-root {
    color: var(--fg);
  }

  .prompt-path {
    color: var(--fg);
    text-decoration: none;
  }

  a.prompt-path:hover {
    color: var(--accent-bright);
  }

  .prompt-path-current {
    color: var(--fg);
  }

  .prompt-dollar {
    color: var(--green);
    margin-left: 0.25ch;
  }

  .cursor {
    display: inline-block;
    width: 0.8ch;
    height: 1.1em;
    background-color: var(--cursor);
    margin-left: 0.25ch;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }
</style>
