---
import { PALETTES } from '../lib/palettes';

const PALETTE_LABELS: Record<string, string> = {
  'dark-terminal': 'dark terminal',
  'amber-crt': 'amber crt',
  'green-phosphor': 'green phosphor',
  'synthwave': 'synthwave',
  'mocha': 'mocha',
  'solarized': 'solarized',
  'gruvbox': 'gruvbox',
  'nord': 'nord',
};
---
<label class="palette-picker">
  <span class="palette-prompt">$ palette --set</span>
  <span class="palette-select-wrap">
    <select id="palette-select" class="palette-select" aria-label="Color palette">
      {PALETTES.map(id => (
        <option value={id}>{PALETTE_LABELS[id] ?? id}</option>
      ))}
    </select>
  </span>
</label>

<style>
  .palette-picker {
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    padding-top: 0.35rem;
    font-size: 0.85rem;
    color: var(--fg-muted);
  }

  .palette-prompt {
    color: var(--green);
    white-space: nowrap;
  }

  .palette-select-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .palette-select {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--fg);
    font: inherit;
    padding: 0.15rem 1.75ch 0.15rem 0.6ch;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }

  .palette-select:hover,
  .palette-select:focus-visible {
    border-color: var(--accent);
    color: var(--accent);
    outline: none;
  }

  .palette-select-wrap::after {
    content: "▾";
    position: absolute;
    right: 0.5ch;
    top: 50%;
    transform: translateY(-50%);
    color: var(--fg-muted);
    pointer-events: none;
    font-size: 0.75em;
  }

  .palette-select option {
    background-color: var(--bg);
    color: var(--fg);
  }
</style>
