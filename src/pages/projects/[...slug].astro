---
import { getCollection, render } from 'astro:content';
import Page from '../../layouts/Page.astro';
import TerminalFrame from '../../components/TerminalFrame.astro';

const slug = Astro.params.slug;
const projects = await getCollection('projects');
const project = projects.find(p => p.id === slug);
if (!project) return Astro.redirect('/projects');
const { Content } = await render(project);
const dateStr = project.data.date.toISOString().slice(0, 10);
const stackStr = project.data.stack.join(' · ');
---
<Page title={project.data.title} path="/projects">
  <TerminalFrame title={`cat ~/projects/${project.id}/README.md`}>
    <div class="project-meta">
      <div class="meta-row">
        <span class="meta-key">Status</span>
        <span class="meta-value status">{project.data.status}</span>
      </div>
      <div class="meta-row">
        <span class="meta-key">Stack</span>
        <span class="meta-value muted">{stackStr}</span>
      </div>
      <div class="meta-row">
        <span class="meta-key">Updated</span>
        <span class="meta-value muted">{dateStr}</span>
      </div>
      {project.data.url && (
        <div class="meta-row">
          <span class="meta-key">URL</span>
          <a class="meta-value link" href={project.data.url} target="_blank" rel="noopener noreferrer">{project.data.url}</a>
        </div>
      )}
      <div class="meta-row">
        <span class="meta-key">Repo</span>
        {project.data.repo
          ? <a class="meta-value link" href={project.data.repo} target="_blank" rel="noopener noreferrer">{project.data.repo}</a>
          : <span class="meta-value muted">closed source</span>
        }
      </div>
    </div>
    <hr class="divider" />
    <div class="project-content">
      <Content />
    </div>
  </TerminalFrame>
</Page>

<style>
  .project-meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-bottom: 1rem;
    font-size: 0.85rem;
  }

  .meta-row {
    display: flex;
    gap: 1rem;
  }

  .meta-key {
    color: var(--fg-muted);
    min-width: 6rem;
  }

  .meta-value {
    color: var(--fg);
  }

  .meta-value.status {
    color: var(--amber);
  }

  .meta-value.muted {
    color: var(--fg-muted);
  }

  .meta-value.link,
  a.meta-value {
    color: var(--accent);
    text-decoration: none;
  }

  .meta-value.link:hover,
  a.meta-value:hover {
    text-decoration: underline;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--fg-muted);
    margin: 1rem 0;
    opacity: 0.3;
  }

  .project-content {
    line-height: 1.65;
  }

  /* Headings */
  .project-content :global(h1),
  .project-content :global(h2),
  .project-content :global(h3),
  .project-content :global(h4),
  .project-content :global(h5),
  .project-content :global(h6) {
    color: var(--accent);
    font-weight: bold;
    line-height: 1.3;
  }

  .project-content :global(h1) { font-size: 1.6rem; margin: 2rem 0 1rem; }
  .project-content :global(h2) { font-size: 1.35rem; margin: 1.75rem 0 0.85rem; }
  .project-content :global(h3) { font-size: 1.15rem; margin: 1.5rem 0 0.7rem; }
  .project-content :global(h4) { font-size: 1rem; margin: 1.25rem 0 0.5rem; }
  .project-content :global(h5) { font-size: 0.95rem; margin: 1.15rem 0 0.45rem; }
  .project-content :global(h6) { font-size: 0.9rem; margin: 1rem 0 0.4rem; color: var(--fg-muted); }

  .project-content :global(h1:first-child),
  .project-content :global(h2:first-child),
  .project-content :global(h3:first-child),
  .project-content :global(h4:first-child) {
    margin-top: 0;
  }

  /* Paragraphs */
  .project-content :global(p) {
    margin: 0 0 1rem;
  }

  /* Inline emphasis */
  .project-content :global(strong) {
    color: var(--fg);
    font-weight: bold;
  }

  .project-content :global(em) {
    color: var(--fg);
    font-style: italic;
  }

  .project-content :global(del) {
    color: var(--fg-muted);
  }

  /* Lists — reset global zeroing and give markers breathing room */
  .project-content :global(ul),
  .project-content :global(ol) {
    margin: 0 0 1rem;
    padding-left: 2rem;
  }

  .project-content :global(ul) { list-style: disc outside; }
  .project-content :global(ol) { list-style: decimal outside; }

  .project-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .project-content :global(li:last-child) {
    margin-bottom: 0;
  }

  .project-content :global(li > p) {
    margin-bottom: 0.5rem;
  }

  .project-content :global(li::marker) {
    color: var(--fg-muted);
  }

  /* Nested lists */
  .project-content :global(ul ul),
  .project-content :global(ul ol),
  .project-content :global(ol ul),
  .project-content :global(ol ol) {
    margin: 0.5rem 0 0;
  }

  /* GFM task lists */
  .project-content :global(ul.contains-task-list) {
    list-style: none;
    padding-left: 0.5rem;
  }

  .project-content :global(.task-list-item) {
    padding-left: 0;
  }

  .project-content :global(.task-list-item input[type="checkbox"]) {
    margin-right: 0.5rem;
    accent-color: var(--accent);
    transform: translateY(1px);
  }

  /* Blockquote */
  .project-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    color: var(--fg-muted);
    background-color: color-mix(in srgb, var(--bg-surface) 60%, transparent);
    border-radius: 0 3px 3px 0;
  }

  .project-content :global(blockquote p) {
    margin-bottom: 0.5rem;
  }

  .project-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* Tables */
  .project-content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.9rem;
    display: block;
    overflow-x: auto;
  }

  .project-content :global(th),
  .project-content :global(td) {
    border: 1px solid var(--border);
    padding: 0.55rem 0.85rem;
    text-align: left;
  }

  .project-content :global(th) {
    background-color: var(--bg-surface);
    color: var(--accent);
    font-weight: bold;
  }

  .project-content :global(tbody tr:nth-child(even)) {
    background-color: color-mix(in srgb, var(--bg-surface) 40%, transparent);
  }

  /* Horizontal rule */
  .project-content :global(hr) {
    border: none;
    border-top: 1px dashed var(--border);
    margin: 2rem 0;
  }

  /* Links */
  .project-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .project-content :global(a:hover) {
    color: var(--accent-bright);
  }

  /* Images */
  .project-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 3px;
    margin: 1rem 0;
    display: block;
  }

  /* Code */
  .project-content :global(code) {
    background-color: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.1em 0.35em;
    font-family: inherit;
    font-size: 0.9em;
    color: var(--accent);
  }

  .project-content :global(pre) {
    background-color: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1rem;
    overflow-x: auto;
    margin: 0 0 1rem;
    line-height: 1.5;
    font-size: 0.9rem;
  }

  .project-content :global(pre code) {
    padding: 0;
    background: none;
    border: none;
    color: inherit;
    font-size: inherit;
  }

  /* Footnotes (GFM) */
  .project-content :global(.footnotes) {
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--fg-muted);
  }

  .project-content :global(.footnotes ol) {
    padding-left: 1.5rem;
  }

  .project-content :global(.footnotes li) {
    margin-bottom: 0.4rem;
  }
</style>
