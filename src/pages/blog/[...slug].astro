---
import { getCollection, render } from 'astro:content';
import Page from '../../layouts/Page.astro';
import TerminalFrame from '../../components/TerminalFrame.astro';

const slug = Astro.params.slug;
const posts = await getCollection('blog', ({ data }) => !data.draft);
const post = posts.find(p => p.id === slug);
if (!post) return Astro.redirect('/blog');
const { Content } = await render(post);
const dateStr = post.data.date.toISOString().slice(0, 10);
const tagsStr = post.data.tags.join(', ');
---
<Page title={post.data.title} path="/blog">
  <TerminalFrame title={`cat ~/blog/${post.id}.md`}>
    <p class="post-meta">{dateStr} · {tagsStr}</p>
    <div class="post-content">
      <Content />
    </div>
  </TerminalFrame>
</Page>

<style>
  .post-meta {
    font-size: 0.85rem;
    color: var(--fg-muted);
    margin: 0 0 1.5rem;
  }

  .post-content {
    line-height: 1.65;
  }

  /* Headings */
  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4),
  .post-content :global(h5),
  .post-content :global(h6) {
    color: var(--accent);
    font-weight: bold;
    line-height: 1.3;
  }

  .post-content :global(h1) { font-size: 1.6rem; margin: 2rem 0 1rem; }
  .post-content :global(h2) { font-size: 1.35rem; margin: 1.75rem 0 0.85rem; }
  .post-content :global(h3) { font-size: 1.15rem; margin: 1.5rem 0 0.7rem; }
  .post-content :global(h4) { font-size: 1rem; margin: 1.25rem 0 0.5rem; }
  .post-content :global(h5) { font-size: 0.95rem; margin: 1.15rem 0 0.45rem; }
  .post-content :global(h6) { font-size: 0.9rem; margin: 1rem 0 0.4rem; color: var(--fg-muted); }

  .post-content :global(h1:first-child),
  .post-content :global(h2:first-child),
  .post-content :global(h3:first-child),
  .post-content :global(h4:first-child) {
    margin-top: 0;
  }

  /* Paragraphs */
  .post-content :global(p) {
    margin: 0 0 1rem;
  }

  /* Inline emphasis */
  .post-content :global(strong) {
    color: var(--fg);
    font-weight: bold;
  }

  .post-content :global(em) {
    color: var(--fg);
    font-style: italic;
  }

  .post-content :global(del) {
    color: var(--fg-muted);
  }

  /* Lists — reset global zeroing and give markers breathing room */
  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 0 0 1rem;
    padding-left: 2rem;
  }

  .post-content :global(ul) { list-style: disc outside; }
  .post-content :global(ol) { list-style: decimal outside; }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(li:last-child) {
    margin-bottom: 0;
  }

  .post-content :global(li > p) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(li::marker) {
    color: var(--fg-muted);
  }

  /* Nested lists */
  .post-content :global(ul ul),
  .post-content :global(ul ol),
  .post-content :global(ol ul),
  .post-content :global(ol ol) {
    margin: 0.5rem 0 0;
  }

  /* GFM task lists */
  .post-content :global(ul.contains-task-list) {
    list-style: none;
    padding-left: 0.5rem;
  }

  .post-content :global(.task-list-item) {
    padding-left: 0;
  }

  .post-content :global(.task-list-item input[type="checkbox"]) {
    margin-right: 0.5rem;
    accent-color: var(--accent);
    transform: translateY(1px);
  }

  /* Blockquote */
  .post-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    color: var(--fg-muted);
    background-color: color-mix(in srgb, var(--bg-surface) 60%, transparent);
    border-radius: 0 3px 3px 0;
  }

  .post-content :global(blockquote p) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* Tables */
  .post-content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.9rem;
    display: block;
    overflow-x: auto;
  }

  .post-content :global(th),
  .post-content :global(td) {
    border: 1px solid var(--border);
    padding: 0.55rem 0.85rem;
    text-align: left;
  }

  .post-content :global(th) {
    background-color: var(--bg-surface);
    color: var(--accent);
    font-weight: bold;
  }

  .post-content :global(tbody tr:nth-child(even)) {
    background-color: color-mix(in srgb, var(--bg-surface) 40%, transparent);
  }

  /* Horizontal rule */
  .post-content :global(hr) {
    border: none;
    border-top: 1px dashed var(--border);
    margin: 2rem 0;
  }

  /* Links */
  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-content :global(a:hover) {
    color: var(--accent-bright);
  }

  /* Images */
  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 3px;
    margin: 1rem 0;
    display: block;
  }

  /* Code */
  .post-content :global(code) {
    background-color: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.1em 0.35em;
    font-family: inherit;
    font-size: 0.9em;
    color: var(--accent);
  }

  .post-content :global(pre) {
    background-color: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1rem;
    overflow-x: auto;
    margin: 0 0 1rem;
    line-height: 1.5;
    font-size: 0.9rem;
  }

  .post-content :global(pre code) {
    padding: 0;
    background: none;
    border: none;
    color: inherit;
    font-size: inherit;
  }

  /* Footnotes (GFM) */
  .post-content :global(.footnotes) {
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--fg-muted);
  }

  .post-content :global(.footnotes ol) {
    padding-left: 1.5rem;
  }

  .post-content :global(.footnotes li) {
    margin-bottom: 0.4rem;
  }
</style>
