---
import Page from '../layouts/Page.astro';
import PageHeader from '../components/PageHeader.astro';
import TerminalFrame from '../components/TerminalFrame.astro';
import '../styles/print.css';
import '../styles/prose.css';

const resumeModule = await import('../data/resume.md');
const ResumeContent = resumeModule.default;
---
<Page title="Resume" path="/resume">
  <PageHeader heading="~/resume" description="less ~/resume — my cv, with a download link at the bottom." />
  <TerminalFrame title="cat ~/resume.md">
    <div class="prose">
      <ResumeContent />
    </div>
  </TerminalFrame>

  <div class="resume-actions">
    <a href="/resume.pdf" class="download-link" download>Download PDF</a>
  </div>
</Page>

<style>
  .resume-actions {
    margin-top: 1rem;
  }

  .download-link {
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent);
    padding: 0.4rem 0.9rem;
    border-radius: 3px;
    font-size: 0.85rem;
    transition: background-color 0.15s, color 0.15s;
  }

  .download-link:hover {
    background-color: var(--accent);
    color: var(--bg);
  }
</style>
